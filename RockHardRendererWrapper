	}, self._frame)
	listLayout(4, row, Enum.FillDirection.Horizontal)
	local obj = {_frame = row}
	for k, v in pairs(ChildBase) do obj[k] = v end
	return obj
end

function ChildBase:TabMenu()
	-- tab bar
	local tabBar = make("Frame", {
		Size             = UDim2.new(1, 0, 0, 26),
		BackgroundColor3 = T.tabBar,
	}, self._frame)
	listLayout(0, tabBar, Enum.FillDirection.Horizontal)

	-- page container (fills remaining height)
	local pageContainer = make("Frame", {
		Size             = UDim2.new(1, 0, 1, -26),
		Position         = UDim2.new(0, 0, 0, 26),
		BackgroundTransparency = 1,
	}, self._frame)
	padding(6, 6, 6, 6, pageContainer)

	local pages, btns = {}, {}
	local obj = {
		_tabBar        = tabBar,
		_pageContainer = pageContainer,
		_pages         = pages,
		_tabBtns       = btns,
		SelectedItem   = 0,
		OnUpdated      = signal(),
	}

	function obj:Add(label)
		local scroll = make("ScrollingFrame", {
			Size                 = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			ScrollBarThickness   = 3,
			ScrollBarImageColor3 = T.accent,
			CanvasSize           = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize  = Enum.AutomaticSize.Y,
			Visible              = false,
		}, pageContainer)
		listLayout(4, scroll)

		local tabBtn = make("TextButton", {
			Size             = UDim2.new(0, 0, 1, 0),
			AutomaticSize    = Enum.AutomaticSize.X,
			BackgroundColor3 = T.tabInact,
			Text             = label,
			TextColor3       = T.textDim,
			Font             = T.font,
			TextSize         = T.fontSz,
			AutoButtonColor  = false,
			BorderSizePixel  = 0,
		}, tabBar)
		padding(0, 0, 12, 12, tabBtn)

		table.insert(pages, scroll)
		table.insert(btns, tabBtn)
		local myIdx = #pages

		local function select(idx)
			for i, p in ipairs(pages) do
				p.Visible = (i == idx)
				btns[i].BackgroundColor3 = (i == idx) and T.tabActive or T.tabInact
				btns[i].TextColor3 = (i == idx) and T.white or T.textDim
			end
			obj.SelectedItem = idx
			obj.OnUpdated:Fire(idx)
		end

		tabBtn.MouseEnter:Connect(function()
			if myIdx ~= obj.SelectedItem then tabBtn.BackgroundColor3 = T.tabHov end
		end)
		tabBtn.MouseLeave:Connect(function()
			if myIdx ~= obj.SelectedItem then tabBtn.BackgroundColor3 = T.tabInact end
		end)
		tabBtn.MouseButton1Click:Connect(function() select(myIdx) end)

		if myIdx == 1 then select(1) end

		local page = {_frame = scroll}
		for k, v in pairs(ChildBase) do page[k] = v end
		return page
	end

	return obj
end

-- ─── RenderWindow ─────────────────────────────────────────────────────────────

RenderWindow = {}
RenderWindow.__index = RenderWindow

function RenderWindow.new(title)
	local gui = Instance.new("ScreenGui")
	gui.Name = "RenderWindow"
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.DisplayOrder = 100

	local ok = pcall(function() gui.Parent = game:GetService("CoreGui") end)
	if not ok then gui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end

	-- outer shadow/border frame
	local shadow = make("Frame", {
		Size             = UDim2.new(0, 324, 0, 404),
		Position         = UDim2.new(0.5, -162, 0.5, -202),
		BackgroundColor3 = Color3.fromRGB(15, 15, 15),
		BorderSizePixel  = 0,
	}, gui)
	corner(UDim.new(0, 5), shadow)

	local root = make("Frame", {
		Size             = UDim2.new(1, -2, 1, -2),
		Position         = UDim2.new(0, 1, 0, 1),
		BackgroundColor3 = T.win,
		BorderSizePixel  = 0,
		ClipsDescendants = true,
	}, shadow)
	corner(UDim.new(0, 4), root)

	-- title bar
	local titleBar = make("Frame", {
		Size             = UDim2.new(1, 0, 0, 24),
		BackgroundColor3 = T.titleBar,
		BorderSizePixel  = 0,
	}, root)

	make("TextLabel", {
		Size                = UDim2.new(1, -28, 1, 0),
		Position            = UDim2.new(0, 8, 0, 0),
		BackgroundTransparency = 1,
		Text                = "▼  " .. title,
		TextColor3          = T.text,
		Font                = T.font,
		TextSize            = T.fontSz,
		TextXAlignment      = Enum.TextXAlignment.Left,
	}, titleBar)

	local closeBtn = make("TextButton", {
		Size             = UDim2.new(0, 16, 0, 16),
		Position         = UDim2.new(1, -20, 0.5, -8),
		BackgroundColor3 = Color3.fromRGB(180, 40, 40),
		Text             = "×",
		TextColor3       = T.white,
		Font             = T.font,
		TextSize         = 14,
		AutoButtonColor  = false,
		BorderSizePixel  = 0,
	}, titleBar)
	corner(UDim.new(0, 2), closeBtn)

	closeBtn.MouseButton1Click:Connect(function()
		root.Visible = not root.Visible
	end)

	-- thin separator line under title
	make("Frame", {
		Size             = UDim2.new(1, 0, 0, 1),
		Position         = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = T.accent,
		BorderSizePixel  = 0,
	}, titleBar)

	draggable(titleBar, shadow)

	local content = make("Frame", {
		Size             = UDim2.new(1, 0, 1, -24),
		Position         = UDim2.new(0, 0, 0, 24),
		BackgroundTransparency = 1,
	}, root)

	local self = setmetatable({
		_gui             = gui,
		_root            = shadow,
		_frame           = content,
		WindowName       = title,
		MinSize          = nil,
		MaxSize          = nil,
		DefaultSize      = Vector2.new(320, 400),
		CanResize        = false,
		VisibilityOverride = false,
		Visible          = true,
	}, RenderWindow)

	for k, v in pairs(ChildBase) do
		if RenderWindow[k] == nil then RenderWindow[k] = v end
	end

	return self
end

function RenderWindow:Emplace(newName)
	if newName then
		self.WindowName = newName
	end
	self._root.Visible = true
end
