function ChildBase:Collapsable(name, defaultOpen)
	local wrapper = make("Frame", {Size = UDim2.new(1, 0, 0, 20), BackgroundTransparency = 1}, self._frame)

	local hbtn = make("TextButton", {
		Size             = UDim2.new(1, 0, 0, 20),
		BackgroundColor3 = T.widget,
		Text             = "",
		AutoButtonColor  = false,
	}, wrapper)
	corner(nil, hbtn)

	local arrowlbl = make("TextLabel", {
		Size                = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text                = "",
		TextColor3          = T.text,
		Font                = T.font,
		TextSize            = T.fontSz,
		TextXAlignment      = Enum.TextXAlignment.Left,
	}, hbtn)
	padding(0, 0, 8, 0, arrowlbl)

	local content = make("Frame", {
		Size             = UDim2.new(1, -8, 0, 0),
		Position         = UDim2.new(0, 8, 0, 22),
		BackgroundTransparency = 1,
	}, wrapper)
	local cl = listLayout(3, content)

	local isOpen = defaultOpen or false

	local function refresh()
		local h = cl.AbsoluteContentSize.Y
		content.Size = UDim2.new(1, -8, 0, h)
		wrapper.Size = UDim2.new(1, 0, 0, 20 + (content.Visible and h + 4 or 0))
	end

	cl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refresh)
	content.Visible = isOpen
	arrowlbl.Text = (isOpen and "▼  " or "▶  ") .. name
	refresh()

	hbtn.MouseEnter:Connect(function() hbtn.BackgroundColor3 = T.widgetHov end)
	hbtn.MouseLeave:Connect(function() hbtn.BackgroundColor3 = T.widget end)
	hbtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		content.Visible = isOpen
		arrowlbl.Text = (isOpen and "▼  " or "▶  ") .. name
		refresh()
	end)

	local obj = {_frame = content}
	for k, v in pairs(ChildBase) do obj[k] = v end
	return obj
end

function ChildBase:SameLine()
	local row = make("Frame", {
		Size             = UDim2.new(1, 0, 0, 22),
