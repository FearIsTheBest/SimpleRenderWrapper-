local Ui = {}

do
    local Page = {}

    Ui.__index = Ui
    Page.__index = Page

    local UIS = game:GetService("UserInputService")

    -- helpers
    local function make(class, props, parent)
        local obj = Instance.new(class)
        for k, v in pairs(props) do obj[k] = v end
        if parent then obj.Parent = parent end
        return obj
    end

    local function corner(r, p) make("UICorner", {CornerRadius = UDim.new(0, r)}, p) end
    local function padding(t, b, l, r, p) make("UIPadding", {PaddingTop=UDim.new(0,t), PaddingBottom=UDim.new(0,b), PaddingLeft=UDim.new(0,l), PaddingRight=UDim.new(0,r)}, p) end
    local function listLayout(spacing, parent)
        return make("UIListLayout", {SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0, spacing)}, parent)
    end

    local THEME = {
        bg         = Color3.fromRGB(18, 18, 24),
        header     = Color3.fromRGB(28, 28, 38),
        accent     = Color3.fromRGB(100, 80, 220),
        element    = Color3.fromRGB(32, 32, 44),
        elementHov = Color3.fromRGB(44, 44, 60),
        divider    = Color3.fromRGB(50, 50, 68),
        text       = Color3.fromRGB(220, 220, 240),
        textDim    = Color3.fromRGB(140, 140, 160),
        white      = Color3.fromRGB(255, 255, 255),
        font       = Enum.Font.GothamMedium,
        fontBold   = Enum.Font.GothamBold,
    }

    local function makeDraggable(handle, root)
        local dragging, dragStart, startPos
        handle.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true; dragStart = i.Position; startPos = root.Position
            end
        end)
        handle.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
        UIS.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - dragStart
                root.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
            end
        end)
    end

    -- Ui class
    do
        function Ui.new(title: string, size: Vector2?)
            size = size or Vector2.new(300, 400)

            local gui = Instance.new("ScreenGui")
            gui.Name = "RockHardRendererWrapper"
            gui.ResetOnSpawn = false
            gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
            local ok = pcall(function() gui.Parent = game:GetService("CoreGui") end)
            if not ok then gui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end

            local root = make("Frame", {
                Size = UDim2.new(0, size.X, 0, size.Y),
                Position = UDim2.new(0.5, -size.X/2, 0.5, -size.Y/2),
                BackgroundColor3 = THEME.bg,
                ClipsDescendants = true,
            }, gui)
            corner(10, root)
            make("UIStroke", {Color = THEME.divider, Thickness = 1}, root)

            local titleBar = make("Frame", {Size = UDim2.new(1,0,0,36), BackgroundColor3 = THEME.header}, root)
            make("Frame", {Size=UDim2.new(1,0,0,10), Position=UDim2.new(0,0,1,-10), BackgroundColor3=THEME.header}, titleBar)
            make("TextLabel", {Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,12,0,0), BackgroundTransparency=1, Text=title, TextColor3=THEME.text, Font=THEME.fontBold, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left}, titleBar)

            local closeBtn = make("TextButton", {Size=UDim2.new(0,24,0,24), Position=UDim2.new(1,-28,0.5,-12), BackgroundColor3=Color3.fromRGB(200,60,60), Text="×", TextColor3=THEME.white, Font=THEME.fontBold, TextSize=16, AutoButtonColor=false}, titleBar)
            corner(6, closeBtn)
            closeBtn.MouseButton1Click:Connect(function() root.Visible = not root.Visible end)
            makeDraggable(titleBar, root)

            local tabBar = make("Frame", {Size=UDim2.new(1,0,0,28), Position=UDim2.new(0,0,0,36), BackgroundColor3=THEME.header}, root)
            make("Frame", {Size=UDim2.new(1,0,0,10), BackgroundColor3=THEME.header}, tabBar)
            make("UIListLayout", {FillDirection=Enum.FillDirection.Horizontal, SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,2)}, tabBar)
            padding(4,4,6,6, tabBar)

            local pageContainer = make("Frame", {Size=UDim2.new(1,0,1,-64), Position=UDim2.new(0,0,0,64), BackgroundTransparency=1}, root)

            return setmetatable({
                _gui = gui,
                _root = root,
                _tabBar = tabBar,
                _pageContainer = pageContainer,
                _pages = {},
                _tabBtns = {},
            }, Ui)
        end

        function Ui:addPage(name: string)
            local scroll = make("ScrollingFrame", {
                Size = UDim2.new(1,0,1,0),
                BackgroundTransparency = 1,
                ScrollBarThickness = 3,
                ScrollBarImageColor3 = THEME.accent,
                CanvasSize = UDim2.new(0,0,0,0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                Visible = false,
            }, self._pageContainer)
            padding(6,6,6,6, scroll)
            listLayout(5, scroll)

            local tabBtn = make("TextButton", {
                Size = UDim2.new(0,0,1,0),
                AutomaticSize = Enum.AutomaticSize.X,
                BackgroundColor3 = THEME.element,
                Text = "  "..name.."  ",
                TextColor3 = THEME.textDim,
                Font = THEME.font,
                TextSize = 12,
                AutoButtonColor = false,
            }, self._tabBar)
            corner(5, tabBtn)
            padding(0,0,8,8, tabBtn)

            table.insert(self._pages, scroll)
            table.insert(self._tabBtns, tabBtn)

            local pages, btns = self._pages, self._tabBtns
            local function select(idx)
                for i, p in ipairs(pages) do
                    p.Visible = (i == idx)
                    btns[i].TextColor3 = (i == idx) and THEME.text or THEME.textDim
                    btns[i].BackgroundColor3 = (i == idx) and THEME.accent or THEME.element
                end
            end

            local myIdx = #self._pages
            tabBtn.MouseButton1Click:Connect(function() select(myIdx) end)
            if myIdx == 1 then select(1) end

            return Page.new(scroll)
        end
    end

    -- Page class
    do
        function Page.new(frame)
            return setmetatable({page = frame}, Page)
        end

        function Page:addDivider(name: string)
            local frame = make("Frame", {Size=UDim2.new(1,0,0,20), BackgroundTransparency=1}, self.page)
            make("Frame", {Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,0.5,0), BackgroundColor3=THEME.divider}, frame)
            if name and #name > 0 then
                make("TextLabel", {
                    Size=UDim2.new(0,0,1,0), AutomaticSize=Enum.AutomaticSize.X,
                    Position=UDim2.new(0.5,0,0,0), AnchorPoint=Vector2.new(0.5,0),
                    BackgroundColor3=THEME.bg, Text="  "..name.."  ",
                    TextColor3=THEME.textDim, Font=THEME.font, TextSize=11,
                }, frame)
            end
        end

        function Page:addButton(name: string, callback: () -> ())
            local btn = make("TextButton", {
                Size=UDim2.new(1,0,0,32), BackgroundColor3=THEME.element,
                Text=name, TextColor3=THEME.text, Font=THEME.font, TextSize=13, AutoButtonColor=false,
            }, self.page)
            corner(6, btn)
            btn.MouseEnter:Connect(function() btn.BackgroundColor3 = THEME.elementHov end)
            btn.MouseLeave:Connect(function() btn.BackgroundColor3 = THEME.element end)
            btn.MouseButton1Click:Connect(callback)
            return btn
        end

        function Page:addToggle(name: string, callback: (enabled: boolean) -> ())
            local row = make("Frame", {Size=UDim2.new(1,0,0,32), BackgroundColor3=THEME.element}, self.page)
            corner(6, row)
            make("TextLabel", {Size=UDim2.new(1,-52,1,0), Position=UDim2.new(0,10,0,0), BackgroundTransparency=1, Text=name, TextColor3=THEME.text, Font=THEME.font, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left}, row)

            local track = make("Frame", {Size=UDim2.new(0,36,0,20), Position=UDim2.new(1,-46,0.5,-10), BackgroundColor3=Color3.fromRGB(55,55,72)}, row)
            corner(10, track)
            local knob = make("Frame", {Size=UDim2.new(0,14,0,14), Position=UDim2.new(0,3,0.5,-7), BackgroundColor3=THEME.white}, track)
            corner(7, knob)

            local state = false
            local hitbox = make("TextButton", {Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text=""}, row)
            hitbox.MouseButton1Click:Connect(function()
                state = not state
                track.BackgroundColor3 = state and THEME.accent or Color3.fromRGB(55,55,72)
                knob.Position = state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
                callback(state)
            end)
            return row
        end

        function Page:addSlider(name: string, min: number, max: number, callback: (value: number) -> ())
            local frame = make("Frame", {Size=UDim2.new(1,0,0,44), BackgroundColor3=THEME.element}, self.page)
            corner(6, frame)
            padding(6,6,10,10, frame)

            local inner = make("Frame", {Size=UDim2.new(1,0,1,0), BackgroundTransparency=1}, frame)
            local il = listLayout(4, inner)

            local headerRow = make("Frame", {Size=UDim2.new(1,0,0,14), BackgroundTransparency=1}, inner)
            make("TextLabel", {Size=UDim2.new(0.7,0,1,0), BackgroundTransparency=1, Text=name, TextColor3=THEME.text, Font=THEME.font, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left}, headerRow)
            local valLabel = make("TextLabel", {Size=UDim2.new(0.3,0,1,0), Position=UDim2.new(0.7,0,0,0), BackgroundTransparency=1, Text=tostring(min), TextColor3=THEME.textDim, Font=THEME.font, TextSize=12, TextXAlignment=Enum.TextXAlignment.Right}, headerRow)

            local track = make("Frame", {Size=UDim2.new(1,0,0,6), BackgroundColor3=THEME.divider}, inner)
            corner(3, track)
            local fill = make("Frame", {Size=UDim2.new(0,0,1,0), BackgroundColor3=THEME.accent}, track)
            corner(3, fill)

            il:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                inner.Size = UDim2.new(1,0,0,il.AbsoluteContentSize.Y)
            end)

            local dragging = false
            local function update(x)
                local t = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + t*(max-min) + 0.5)
                fill.Size = UDim2.new(t,0,1,0)
                valLabel.Text = tostring(val)
                callback(val)
            end
            track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=true; update(i.Position.X) end end)
            UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end end)
            UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i.Position.X) end end)

            return frame
        end

        function Page:addDropdown(name: string, items: {string}, callback: ((newSelection: any) -> ())?)
            local frame = make("Frame", {Size=UDim2.new(1,0,0,32), BackgroundColor3=THEME.element, ClipsDescendants=true}, self.page)
            corner(6, frame)

            make("TextLabel", {Size=UDim2.new(0.55,0,0,32), Position=UDim2.new(0,10,0,0), BackgroundTransparency=1, Text=name, TextColor3=THEME.text, Font=THEME.font, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left}, frame)
            local selLabel = make("TextLabel", {Size=UDim2.new(0.4,0,0,32), Position=UDim2.new(0.55,-10,0,0), BackgroundTransparency=1, Text=items[1] or "", TextColor3=THEME.accent, Font=THEME.font, TextSize=13, TextXAlignment=Enum.TextXAlignment.Right}, frame)

            local list = make("Frame", {Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,0,0,32), BackgroundColor3=THEME.bg, Visible=false}, frame)
            corner(6, list)
            local ll = listLayout(2, list)
            padding(4,4,4,4, list)

            for _, opt in ipairs(items) do
                local ob = make("TextButton", {Size=UDim2.new(1,-8,0,26), BackgroundColor3=THEME.element, Text=opt, TextColor3=THEME.text, Font=THEME.font, TextSize=12, AutoButtonColor=false}, list)
                corner(4, ob)
                ob.MouseEnter:Connect(function() ob.BackgroundColor3 = THEME.elementHov end)
                ob.MouseLeave:Connect(function() ob.BackgroundColor3 = THEME.element end)
                ob.MouseButton1Click:Connect(function()
                    selLabel.Text = opt
                    list.Visible = false
                    frame.Size = UDim2.new(1,0,0,32)
                    frame.ClipsDescendants = true
                    if callback then callback(opt) end
                end)
            end

            ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                list.Size = UDim2.new(1,0,0,ll.AbsoluteContentSize.Y+8)
            end)

            local open = false
            make("TextButton", {Size=UDim2.new(1,0,0,32), BackgroundTransparency=1, Text=""}, frame).MouseButton1Click:Connect(function()
                open = not open
                list.Visible = open
                if open then
                    frame.ClipsDescendants = false
                    frame.Size = UDim2.new(1,0,0,32 + ll.AbsoluteContentSize.Y + 12)
                else
                    frame.ClipsDescendants = true
                    frame.Size = UDim2.new(1,0,0,32)
                end
            end)

            return frame
        end

        function Page:addTextBox(name: string, callback: ((value: string) -> ())?)
            local frame = make("Frame", {Size=UDim2.new(1,0,0,32), BackgroundColor3=THEME.element}, self.page)
            corner(6, frame)
            make("TextLabel", {Size=UDim2.new(0.5,0,1,0), Position=UDim2.new(0,10,0,0), BackgroundTransparency=1, Text=name, TextColor3=THEME.text, Font=THEME.font, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left}, frame)

            local box = make("TextBox", {Size=UDim2.new(0.45,-6,0,22), Position=UDim2.new(0.55,0,0.5,-11), BackgroundColor3=THEME.bg, Text="", PlaceholderText="Enter value...", TextColor3=THEME.text, PlaceholderColor3=THEME.textDim, Font=THEME.font, TextSize=12, ClearTextOnFocus=false}, frame)
            corner(4, box)
            padding(0,0,6,6, box)

            box.FocusLost:Connect(function(enter)
                if enter and #box.Text > 0 and callback then callback(box.Text) end
            end)
            return frame
        end

        function Page:addCollapsable(name: string, open: boolean?)
            local wrapper = make("Frame", {Size=UDim2.new(1,0,0,30), BackgroundTransparency=1, ClipsDescendants=false}, self.page)

            local headerBtn = make("TextButton", {Size=UDim2.new(1,0,0,28), BackgroundColor3=THEME.header, Text="", AutoButtonColor=false}, wrapper)
            corner(6, headerBtn)
            make("TextLabel", {Size=UDim2.new(1,-30,1,0), Position=UDim2.new(0,10,0,0), BackgroundTransparency=1, Text=name, TextColor3=THEME.text, Font=THEME.fontBold, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left}, headerBtn)
            local arrow = make("TextLabel", {Size=UDim2.new(0,20,1,0), Position=UDim2.new(1,-24,0,0), BackgroundTransparency=1, Text="▼", TextColor3=THEME.textDim, Font=THEME.font, TextSize=10}, headerBtn)

            local content = make("Frame", {Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,0,0,30), BackgroundColor3=THEME.bg, ClipsDescendants=false}, wrapper)
            corner(6, content)
            padding(6,6,6,6, content)
            local cl = listLayout(4, content)

            local function refresh()
                local h = cl.AbsoluteContentSize.Y + 12
                content.Size = UDim2.new(1,0,0,h)
                wrapper.Size = UDim2.new(1,0,0,30 + (content.Visible and h+2 or 0))
            end
            cl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refresh)

            local isOpen = open or false
            content.Visible = isOpen
            arrow.Text = isOpen and "▲" or "▼"
            refresh()

            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                content.Visible = isOpen
                arrow.Text = isOpen and "▲" or "▼"
                refresh()
            end)

            return Page.new(content)
        end

        function Page:addSameLine()
            local row = make("Frame", {Size=UDim2.new(1,0,0,32), BackgroundTransparency=1}, self.page)
            return Page.new(row)
        end
    end
end

return Ui
